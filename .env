# Model & Hardware
MODEL_NAME=Qwen/Qwen3.5-2B
QUANT=
GPU_UTIL=0.95
MAX_LEN=16384
DTYPE=bfloat16

# Reasoning & Templates
# Set to 'qwen' or 'deepseek' if using a reasoning model, otherwise leave empty
#REASONING_PARSER=qwen3
# This string must be valid JSON for vLLM
#CHAT_TEMPLATE_KWARGS='{"enable_thinking": false}'

# Performance
MAX_NUM_SEQS=16
MAX_NUM_BATCHED_TOKENS=4096
